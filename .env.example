# 数据集根目录。支持相对项目根目录或绝对路径。
AUG_DATASET_PATH=dataset/pose/*****************

# 数据集类型：auto 会根据 data.yaml 自动判断。
# detection 表示当前项目使用的点集/轮廓标签。
# pose 表示 YOLO pose 标签。
AUG_DATASET_TYPE=pose

# 每张原图生成多少张增强图。
AUG_NUM_AUG=10

# 输出根目录。留空时输出到数据集同级目录。
AUG_OUTPUT_ROOT=

# 是否额外保存带标注的可视化图片。
AUG_SAVE_LABELED=true

# 开启 resize 时使用的目标尺寸。
AUG_RESIZE_WIDTH=640
AUG_RESIZE_HEIGHT=640

# 增强步骤，按顺序执行。当前支持：resize,rotate,hflip,vflip
AUG_TRANSFORMS=resize,hflip,vflip,rotate

# 左右翻转概率。只有启用 hflip 时生效。
AUG_HORIZONTAL_FLIP_P=0.5

# 上下翻转概率。只有启用 vflip 时生效。
AUG_VERTICAL_FLIP_P=0.5

# 旋转概率和最大旋转角度。只有启用 rotate 时生效。
AUG_ROTATE_P=0.5
AUG_ROTATE_LIMIT=90